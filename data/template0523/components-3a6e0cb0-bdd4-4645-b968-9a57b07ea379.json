oin material_master mm on mm.material_no = ebi.material_no\n  left join material_bom_item  mbi on mbi.customer_no = ebi.customer_no and mbi.system_type = ebi.system_type and mbi.material_no = child.hf_part_no and mbi.component_no = ebi.material_no  and mbi.characteristic = 'ASSEMBLY'\n where ebi.system_type = 'QUOTE'\n  AND ebi.customer_no = :customerCode\n  AND ebi.characteristic = (\n    SELECT\n      MAX(c.characteristic)\n    FROM\n      element_bom_item c\n    WHERE\n      c.system_type = ebi.system_type\n      and c.customer_no = ebi.customer_no\n      AND c.material_no = ebi.material_no\n  )\n  ","declaredColumns":[{"name":"hf_part_no","dataType":"varchar","nullable":false},{"name":"子件","dataType":"varchar","nullable":false},{"name":"序号","dataType":"int4","nullable":true},{"name":"元素","dataType":"varchar","nullable":true},{"name":"含量","dataType":"numeric","nullable":true},{"name":"单位","dataType":"varchar","nullable":true},{"name":"单重","dataType":"numeric","nullable":true},{"name":"组成用量","dataType":"numeric","nullable":true}],"requiredVariables":["customerCode"],"scope":"COMPONENT","description":null}]},{"code":"COMP-0022","name":"工序","componentType":"NORMAL","columnCount":7,"status":"ACTIVE","dataDriverPath":"$gx_view","fields":[{"name":"子件","notes":"","content":"","is_amount":false,"field_type":"BASIC_DATA","is_subtotal":false,"basic_data_path":"$gx_view.子件"},{"name":"序号","notes":"","content":"","is_amount":false,"field_type":"BASIC_DATA","is_subtotal":false,"basic_data_path":"$gx_view.序号"},{"name":"工序代码","notes":"","content":"","is_amount":false,"field_type":"BASIC_DATA","is_subtotal":false,"basic_data_path":"$gx_view.工序代码"},{"name":"工序","notes":"","content":"","is_amount":false,"field_type":"BASIC_DATA","is_subtotal":false,"basic_data_path":"$gx_view.工序"},{"name":"单价","notes":"","content":"120","is_amount":false,"field_type":"INPUT_NUMBER","is_subtotal":false},{"name":"成材率","notes":"","content":"","is_amount":false,"field_type":"BASIC_DATA","is_subtotal":f