      "sqlViews": [
        {
          "sqlViewName": "pf_view",
          "sqlTemplate": "SELECT\n  up.finished_material_no AS hf_part_no,\n  up.finished_material_no AS _销售料号,\n  up.seq_no AS _项次,\n  COALESCE(pm.process_name, up.operation_no) AS _要素名称,\n  up.pricing_price AS _单价,\n  up.unit AS _单位\nFROM unit_price up\n  LEFT JOIN process_master pm ON pm.process_no = up.operation_no\nWHERE up.system_type = 'QUOTE' AND up.price_type = 'PROCESS' AND up.is_current = true\n  AND up.customer_no = :customerCode\nORDER BY up.seq_no",
          "declaredColumns": [
            {
              "name": "hf_part_no",
              "dataType": "varchar",
              "nullable": true
            },
            {
              "name": "_销售料号",
              "dataType": "varchar",
              "nullable": true
            },
            {
              "name": "_项次",
              "dataType": "int4",
              "nullable": true
            },
            {
              "name": "_要素名称",
              "dataType": "varchar",
              "nullable": true
            },
            {
              "name": "_单价",
              "dataType": "numeric",
              "nullable": true
            },
            {
              "name": "_单位",
              "dataType": "varchar",
              "nullable": true
            }
          ],
          "requiredVariables": [
            "customerCode"
          ],
          "scope": "COMPONENT",
          "description": "加工费 取数视图 — 要素名称=工序名称(process_master.process_name via process_no=operation_no; 兜底operation_no), 替代统称cost_type"
        }
      ]
    },
