          "sqlViewName": "wg_view",
          "sqlTemplate": "SELECT\n  mbi.material_no AS hf_part_no, mbi.material_no AS _销售料号,\n  mbi.component_no AS _组成件料号, mm.material_name AS _组成件名称,\n  mbi.composition_qty AS _组成数量, mbi.issue_unit AS _组成单位\nFROM material_bom_item mbi LEFT JOIN material_master mm ON mm.material_no = mbi.component_no\nWHERE mbi.system_type = 'QUOTE' AND mbi.is_current AND mbi.characteristic = 'OUTSOURCED'\n  AND mbi.customer_no = :customerCode\nORDER BY mbi.material_no, mbi.seq_no",
