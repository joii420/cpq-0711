      "sqlViews": [
        {
          "sqlViewName": "dp_view",
          "sqlTemplate": "SELECT\n  up.code AS hf_part_no, up.code AS _销售料号,\n  NULL::varchar AS _电镀元素名称, NULL::numeric AS _镀层厚度,\n  MAX(CASE WHEN up.cost_type = '电镀加工费' THEN up.pricing_price END) AS _电镀加工费,\n  MAX(CASE WHEN up.cost_type = '电镀材料费' THEN up.pricing_price END) AS _电镀材料费,\n  MAX(up.currency) AS _货币, MAX(up.unit) AS _计价单位\nFROM unit_price up\nWHERE up.system_type = 'QUOTE' AND up.price_type = 'PLATING' AND up.is_current = true\n  AND up.customer_no = :customerCode\nGROUP BY up.code ORDER BY up.code",
