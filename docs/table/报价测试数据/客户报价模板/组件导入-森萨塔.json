      "formulas": [],
      "excelColumns": [],
      "sqlViews": [
        {
          "sqlViewName": "mc_view",
          "sqlTemplate": "SELECT\n  ebi.material_no AS hf_part_no, ebi.material_no AS _销售料号,\n  COALESCE(mr.name, mm2.material_name) AS _材质,\n  ebi.material_part_no AS _材质料号,\n  ebi.component_usage_type AS _产出类型, ebi.base_qty AS _组成数量, ebi.seq_no AS _项次,\n  ebi.component_no AS _元素, ebi.content AS _组成含量, ebi.scrap_rate AS _损耗率,\n  ebi.composition_qty AS _毛重, ebi.issue_unit AS _毛用量单位, up.pricing_price AS _元素单价\nFROM element_bom_item ebi\n  LEFT JOIN material_recipe mr  ON mr.code = ebi.material_part_no\n  LEFT JOIN material_master mm2 ON mm2.material_no = ebi.material_part_no\n  LEFT JOIN unit_price up ON up.code = ebi.component_no AND up.price_type = 'ELEMENT'\n       AND up.is_current AND up.customer_no = ebi.customer_no\nWHERE ebi.system_type = 'QUOTE' AND ebi.is_current AND ebi.customer_no = :customerCode\nORDER BY ebi.material_no, ebi.material_part_no, ebi.seq_no",
          "declaredColumns": [
            {
              "name": "hf_part_no",
              "dataType": "varchar",
              "nullable": false
            },
            {
              "name": "_销售料号",
              "dataType": "varchar",
              "nullable": false
            },
            {
