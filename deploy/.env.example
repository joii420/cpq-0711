# Copy to .env and fill in real values for your environment.
#   cp .env.example .env
#   chmod 600 .env
# Never commit .env to git. Never bake into the Docker image.

# ============================================================================
# HTTP
# ============================================================================
# Host port to publish (frontend entrypoint). Container always listens on 8201.
HTTP_PORT=8200

# ============================================================================
# PostgreSQL 16 (external, reachable from the Docker host)
# ============================================================================
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_NAME=cpq_db
DB_USERNAME=cpq_user
DB_PASSWORD=replace-me

# ============================================================================
# Redis (external, reachable from the Docker host)
# ============================================================================
REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_PASSWORD=replace-me
REDIS_DB=0

# ============================================================================
# Application secrets
# ============================================================================
# Must be exactly 32 ASCII chars. Regenerate with:
#   openssl rand -base64 48 | tr -d '\n/+=' | head -c 32
# CRITICAL: rotate this before production go-live; once data is encrypted with
# a given key, that key cannot be changed without re-encrypting all secrets.
CPQ_ENCRYPTION_KEY=Br70gK6vvP5bvCwQNPm4PU55uI3esEW4

# ============================================================================
# JVM tuning (optional)
# ============================================================================
# Override only if you need a larger heap or different GC.
# JAVA_OPTS=-XX:+UseG1GC -Xms512m -Xmx2g -Duser.timezone=Asia/Shanghai -Dquarkus.http.host=0.0.0.0 -Djava.util.logging.manager=org.jboss.logmanager.LogManager
