# Build outputs
**/target
**/dist
**/build
**/.next
**/out

# Node
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.npm
**/.yarn

# Test artifacts
**/test-results
**/playwright-report
**/coverage
**/.nyc_output

# VCS
**/.git
**/.gitignore
**/.gitattributes

# IDE
**/.idea
**/.vscode
**/.fleet
**/*.iml
**/.DS_Store
**/Thumbs.db

# Logs / runtime
**/*.log
**/logs
**/tmp
**/temp

# Docs / non-build artifacts
docs
scripts
*.md
!cpq-backend/README.md
!cpq-frontend/README.md

# Repo-level junk
.claude
.superpowers
preview.tmp.json
findings.md
progress.md
task_plan.md
cpq-import-debug.log*

# Existing single-service dockerfile templates (not used by main image)
cpq-backend/src/main/docker
cpq-backend/docker-compose.yml

# Maven wrapper (we use the maven base image's mvn, not mvnw)
cpq-backend/mvnw
cpq-backend/mvnw.cmd
cpq-backend/.mvn

# Env / secrets — never bake into image
**/.env
**/.env.*
!**/.env.example

# Build orchestration files don't need to be inside the image context
.dockerignore
Dockerfile
docker-compose.yml
